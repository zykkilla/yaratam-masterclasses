<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Вход — Яратам</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="header">
    <div class="container">
      <a href="/" class="logo">ЯРАТАМ</a>
      <nav class="nav">
        <a href="/">Каталог</a>
        <a href="/auth/login">Вход</a>
        <a href="/auth/register">Регистрация</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <div class="form-container">
      <h1>Вход</h1>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <% if (message) { %>
        <div class="alert alert-<%= message.type %>"><%= message.text %></div>
      <% } %>

      <form method="POST" action="/auth/login" class="form">
        <div class="form-group">
          <label for="username">Имя пользователя</label>
          <input type="text" id="username" name="username" required>
        </div>
        <div class="form-group">
          <label for="password">Пароль</label>
          <input type="password" id="password" name="password" required>
        </div>
        <button type="submit" class="btn btn-large">Войти</button>
      </form>

      <p style="margin-top: 20px; text-align: center; font-size: 13px;">
        Нет аккаунта? <a href="/auth/register" style="color: var(--primary);">Зарегистрироваться</a>
      </p>
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <p>Казанский молодежный центр «Яратам» &copy; 2026</p>
    </div>
  </footer>
</body>
</html>
