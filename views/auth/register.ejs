<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Регистрация — Яратам</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="header">
    <div class="container">
      <a href="/" class="logo">ЯРАТАМ</a>
      <nav class="nav">
        <a href="/">Каталог</a>
        <a href="/auth/login">Вход</a>
        <a href="/auth/register">Регистрация</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <div class="form-container">
      <h1>Регистрация</h1>

      <% if (errors && errors.length > 0) { %>
        <div class="alert alert-error">
          <% errors.forEach(err => { %>
            <p><%= err %></p>
          <% }) %>
        </div>
      <% } %>

      <form method="POST" action="/auth/register" class="form">
        <div class="form-group">
          <label for="username">Имя пользователя</label>
          <input type="text" id="username" name="username" required minlength="3" placeholder="user123">
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required placeholder="user@example.com">
        </div>
        <div class="form-group">
          <label for="password">Пароль</label>
          <input type="password" id="password" name="password" required minlength="4">
        </div>
        <div class="form-group">
          <label for="password2">Повторите пароль</label>
          <input type="password" id="password2" name="password2" required minlength="4">
        </div>
        <button type="submit" class="btn btn-large">Зарегистрироваться</button>
      </form>

      <p style="margin-top: 20px; text-align: center; font-size: 13px;">
        Уже есть аккаунт? <a href="/auth/login" style="color: var(--primary);">Войти</a>
      </p>
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <p>Казанский молодежный центр «Яратам» &copy; 2026</p>
    </div>
  </footer>
</body>
</html>
