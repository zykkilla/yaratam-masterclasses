<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= mc && mc._id ? 'Редактирование' : 'Новый мастер-класс' %> — Яратам</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="header header-admin">
    <div class="container">
      <a href="/" class="logo">ЯРАТАМ</a>
      <nav class="nav">
        <a href="/admin/dashboard">Мастер-классы</a>
        <a href="/">На сайт</a>
        <a href="/admin/logout">Выйти</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <a href="/admin/dashboard" class="back-link">&larr; Назад</a>

    <div class="form-container">
      <h1><%= mc && mc._id ? 'Редактирование' : 'Новый мастер-класс' %></h1>

      <% if (errors && errors.length > 0) { %>
        <div class="alert alert-error">
          <% errors.forEach(err => { %>
            <p><%= err %></p>
          <% }) %>
        </div>
      <% } %>

      <form method="POST" action="<%= mc && mc._id ? '/admin/masterclass/' + mc._id + '/edit' : '/admin/masterclass/new' %>" class="form">
        <div class="form-group">
          <label for="title">Название *</label>
          <input type="text" id="title" name="title" value="<%= mc ? mc.title : '' %>" required minlength="3">
        </div>

        <div class="form-group">
          <label for="description">Описание *</label>
          <textarea id="description" name="description" rows="4" required minlength="10"><%= mc ? mc.description : '' %></textarea>
        </div>

        <div class="form-group">
          <label for="category">Категория *</label>
          <select id="category" name="category" required>
            <option value="">Выберите</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat._id %>" <%= (mc && mc.category === cat._id) ? 'selected' : '' %>><%= cat.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="date">Дата *</label>
            <input type="date" id="date" name="date" value="<%= mc ? mc.date : '' %>" required>
          </div>

          <div class="form-group">
            <label for="time">Время *</label>
            <input type="time" id="time" name="time" value="<%= mc ? mc.time : '' %>" required>
          </div>
        </div>

        <div class="form-group">
          <label for="maxParticipants">Макс. участников *</label>
          <input type="number" id="maxParticipants" name="maxParticipants" value="<%= mc ? mc.maxParticipants : 10 %>" min="1" required>
        </div>

        <button type="submit" class="btn btn-large"><%= mc && mc._id ? 'Сохранить' : 'Создать' %></button>
      </form>
    </div>
  </main>
</body>
</html>
