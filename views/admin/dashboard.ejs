<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Админ-панель — Яратам</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="header header-admin">
    <div class="container">
      <a href="/" class="logo">ЯРАТАМ</a>
      <nav class="nav">
        <a href="/admin/dashboard">Мастер-классы</a>
        <a href="/admin/masterclass/new">Добавить</a>
        <a href="/">На сайт</a>
        <a href="/admin/logout">Выйти</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <% if (message) { %>
      <div class="alert alert-<%= message.type %>"><%= message.text %></div>
    <% } %>

    <div class="admin-header">
      <h1>Управление мастер-классами</h1>
      <a href="/admin/masterclass/new" class="btn">+ Добавить</a>
    </div>

    <p class="stats">Всего записей: <strong><%= totalRegistrations %></strong></p>

    <table class="table">
      <thead>
        <tr>
          <th>Название</th>
          <th>Категория</th>
          <th>Дата</th>
          <th>Записано</th>
          <th>Действия</th>
        </tr>
      </thead>
      <tbody>
        <% masterclasses.forEach(mc => { %>
          <tr>
            <td><%= mc.title %></td>
            <td><%= mc.categoryName %></td>
            <td><%= mc.date %></td>
            <td><%= mc.registeredCount %> / <%= mc.maxParticipants %></td>
            <td class="actions">
              <a href="/admin/masterclass/<%= mc._id %>/edit" class="btn btn-small">Изменить</a>
              <a href="/admin/masterclass/<%= mc._id %>/registrations" class="btn btn-small btn-secondary">Записи</a>
              <form method="POST" action="/admin/masterclass/<%= mc._id %>/delete" style="display:inline;" onsubmit="return confirm('Удалить?')">
                <button type="submit" class="btn btn-small btn-danger">Удалить</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </main>
</body>
</html>
