<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Записи: <%= mc.title %> — Яратам</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="header header-admin">
    <div class="container">
      <a href="/" class="logo">ЯРАТАМ</a>
      <nav class="nav">
        <a href="/admin/dashboard">Мастер-классы</a>
        <a href="/">На сайт</a>
        <a href="/admin/logout">Выйти</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <a href="/admin/dashboard" class="back-link">&larr; Назад</a>

    <h1>Записи: <%= mc.title %></h1>
    <p><%= mc.date %> в <%= mc.time %> | <%= registrations.length %> / <%= mc.maxParticipants %></p>

    <% if (registrations.length === 0) { %>
      <p class="empty">Записей пока нет</p>
    <% } else { %>
      <table class="table">
        <thead>
          <tr>
            <th>Имя</th>
            <th>Email</th>
            <th>Телефон</th>
            <th>Дата записи</th>
          </tr>
        </thead>
        <tbody>
          <% registrations.forEach(reg => { %>
            <tr>
              <td><%= reg.name %></td>
              <td><%= reg.email %></td>
              <td><%= reg.phone %></td>
              <td><%= reg.createdAt.toLocaleDateString('ru-RU') %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </main>
</body>
</html>
