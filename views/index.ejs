<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Яратам — Мастер-классы</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="header">
    <div class="container">
      <a href="/" class="logo">ЯРАТАМ</a>
      <nav class="nav">
        <a href="/">Каталог</a>
        <a href="/my-registrations">Мои записи</a>
        <% if (user) { %>
          <% if (user.role === 'admin') { %>
            <a href="/admin/dashboard">Админ-панель</a>
          <% } %>
          <a href="/profile"><%= user.username %></a>
          <a href="/auth/logout">Выйти</a>
        <% } else { %>
          <a href="/auth/login">Вход</a>
          <a href="/auth/register">Регистрация</a>
        <% } %>
      </nav>
    </div>
  </header>

  <main class="container">
    <% if (message) { %>
      <div class="alert alert-<%= message.type %>"><%= message.text %></div>
    <% } %>

    <section class="hero">
      <h1>Мастер-классы центра «Яратам»</h1>
      <p>Выберите занятие и запишитесь онлайн</p>
    </section>

    <section class="filters">
      <form method="GET" action="/" class="filter-form">
        <select name="category" class="filter-select">
          <option value="">Все категории</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat._id.toString() %>" <%= currentCategory === cat._id.toString() ? 'selected' : '' %>><%= cat.name %></option>
          <% }) %>
        </select>
        <input type="text" name="search" value="<%= search %>" placeholder="Поиск по названию..." class="filter-input">
        <button type="submit" class="btn">Найти</button>
      </form>
    </section>

    <section class="catalog">
      <% if (masterclasses.length === 0) { %>
        <p class="empty">Мастер-классов не найдено</p>
      <% } %>

      <div class="grid">
        <% masterclasses.forEach(mc => { %>
          <div class="card">
            <div class="card-img" style="background-image: url('<%= mc.image %>'); background-size: cover; background-position: center;">
              <span class="card-category"><%= mc.categoryName %></span>
            </div>
            <div class="card-body">
              <h3 class="card-title"><a href="/masterclass/<%= mc._id %>"><%= mc.title %></a></h3>
              <p class="card-date"><%= mc.date %> в <%= mc.time %></p>
              <p class="card-slots">
                <% if (mc.slotsLeft > 0) { %>
                  Свободных мест: <%= mc.slotsLeft %> из <%= mc.maxParticipants %>
                <% } else { %>
                  Места закончились
                <% } %>
              </p>
              <a href="/masterclass/<%= mc._id %>" class="btn btn-small btn-outline">Подробнее</a>
            </div>
          </div>
        <% }) %>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container">
      <p>Казанский молодежный центр «Яратам» &copy; 2026</p>
    </div>
  </footer>
</body>
</html>
